<UserControl
    x:Class="WinUtils.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:WinUtils.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" controls:WheelScroll.Proportional="True">
        <StackPanel Margin="32,20,32,32" MaxWidth="920" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource TitleText}" Text="Performance" />
            <TextBlock
                Margin="0,4,0,20"
                Style="{StaticResource CaptionText}"
                FontSize="14"
                Text="Free up background resources this machine doesn't need." />

            <controls:ToolCard
                x:Name="GamingCard"
                Icon="TopSpeed24"
                Title="Gaming optimize"
                Status="Not scanned">
                <StackPanel>
                    <ui:InfoBar
                        Margin="0,0,0,14"
                        Severity="Informational"
                        IsClosable="False"
                        IsOpen="True"
                        Title="Only a vetted, conservative list"
                        Message="This changes a fixed set of known-safe items (telemetry/printing/bloat services, SysMain, Game DVR background recording and Widgets). Every change is reversible in Windows and none of it touches your games. The process list below is shown for context only." />

                    <controls:RemediationSection
                        x:Name="GamingSection"
                        Description="Turn off background Windows features a gaming-only machine does not need — telemetry/bloat services and Windows Widgets (which keeps msedgewebview2 running). Scan to review; Apply makes the changes stick after a reboot."
                        CompliantTitle="Already optimized"
                        CompliantMessage="Every targeted service is already disabled."
                        AppliedMessage="All targeted services are disabled."
                        RemainingMessage="Re-scan after a reboot if anything remains — some services only stop on restart." />

                    <TextBlock Style="{StaticResource BodyStrongText}" Margin="0,18,0,8" Text="Running processes" />
                    <ItemsControl x:Name="ProcessList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource BodyText}" VerticalAlignment="Center" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Text="{Binding Instances}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource CaptionText}" MinWidth="72" TextAlignment="Right" VerticalAlignment="Center" Text="{Binding Memory}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </controls:ToolCard>

            <controls:ToolCard
                x:Name="PowerPlanCard"
                Icon="Flash24"
                Title="Power plan"
                Status="Checking">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,14"
                        Style="{StaticResource CaptionText}"
                        FontSize="13"
                        Text="Switch between the Balanced and High performance power plans. High performance keeps the CPU ready at all times instead of parking cores and lowering clocks — measurably snappier on desktops, at the cost of more idle power draw." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyStrongText}" Text="High performance plan" />
                            <TextBlock
                                x:Name="PowerPlanStateText"
                                Margin="0,2,0,0"
                                Style="{StaticResource CaptionText}"
                                Text="Checking active plan." />
                        </StackPanel>
                        <ui:ToggleSwitch
                            x:Name="PowerPlanToggle"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Click="OnPowerPlanToggle" />
                    </Grid>

                    <ui:InfoBar
                        x:Name="PowerPlanError"
                        Margin="0,14,0,0"
                        Severity="Error"
                        IsClosable="True"
                        IsOpen="False"
                        Title="Power plan change failed" />
                </StackPanel>
            </controls:ToolCard>

            <controls:ToolCard
                x:Name="IndexingCard"
                Icon="DocumentSearch24"
                Title="Search indexing"
                Status="Checking">
                <StackPanel>
                    <ui:InfoBar
                        Margin="0,0,0,14"
                        Severity="Warning"
                        IsClosable="False"
                        IsOpen="True"
                        Title="Trade-off"
                        Message="The indexer (WSearch) can keep disks busy in the background. Turning it off frees that up, but Start-menu file and document search stops returning results and Outlook search breaks — app and settings search keep working. Skip this on machines where you search for files often." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyStrongText}" Text="Index files for search" />
                            <TextBlock
                                x:Name="IndexingStateText"
                                Margin="0,2,0,0"
                                Style="{StaticResource CaptionText}"
                                Text="Checking service state." />
                        </StackPanel>
                        <ui:ToggleSwitch
                            x:Name="IndexingToggle"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Click="OnIndexingToggle" />
                    </Grid>

                    <ui:InfoBar
                        x:Name="IndexingError"
                        Margin="0,14,0,0"
                        Severity="Error"
                        IsClosable="True"
                        IsOpen="False"
                        Title="Search indexing change failed" />
                </StackPanel>
            </controls:ToolCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
